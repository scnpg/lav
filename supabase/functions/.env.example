# Local Edge Function secrets for `supabase functions serve --env-file supabase/functions/.env`.
#
# SUPABASE_URL / SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY / SUPABASE_DB_URL
# do NOT belong in this file - Supabase injects those automatically into
# every Edge Function at runtime, both locally and when deployed. Setting
# them here would just shadow the real ones.
#
# Everything below is genuinely optional. With none of it set,
# CONTENT_MODERATION_PROVIDER defaults to "mock" and moderate-photo works
# fully offline with fake-but-realistic results. See README "Moderation setup".

# "mock" | "google_vision" | "aws_rekognition"
CONTENT_MODERATION_PROVIDER=mock

# Only used when CONTENT_MODERATION_PROVIDER=google_vision
GOOGLE_CLOUD_VISION_API_KEY=

# Only used when CONTENT_MODERATION_PROVIDER=aws_rekognition
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
