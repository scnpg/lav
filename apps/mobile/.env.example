# Copy this file to .env (same directory) and fill in real values.
# Expo only inlines vars prefixed EXPO_PUBLIC_ into the client bundle - see
# https://docs.expo.dev/guides/environment-variables/. Anything without that
# prefix is invisible to the app, which is intentional: never put a secret
# (like the Supabase service role key) in a var named EXPO_PUBLIC_*.

# Supabase project URL and anon (public) key - Project Settings > API in the
# Supabase dashboard, or printed by `supabase status` for local dev.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Map tile style JSON URL for MapLibre (both native and web). Lav avoids
# Google Maps and Mapbox entirely - see src/lib/mapStyle.ts for the dev
# fallback used when this is unset, and README "Map setup" for self-hosting
# notes and OSM tile usage-policy reminders.
EXPO_PUBLIC_MAP_STYLE_URL=https://demotiles.maplibre.org/style.json
